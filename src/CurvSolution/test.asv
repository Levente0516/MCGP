%% Circle

curve.x = @(t) sin(t);
curve.y = @(t) cos(t);

curve.alpha = 0;    %lower boundary for t
curve.beta = 2*pi;  %upper boundary for t   t \in [alpha, beta]

curve.div = 100; %divison of linspace

curve.boundary(1).alpha = 0;
curve.boundary(1).beta = p

BoundaryConditions(curve)
visualize(curve)